{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Novyx Vault",
  "version": "0.1.0",
  "identifier": "com.novyxlabs.vault",
  "build": {
    "beforeDevCommand": "npm run dev -- -p 3333",
    "devUrl": "http://localhost:3333",
    "beforeBuildCommand": "npm run tauri:prepare",
    "frontendDist": "../.tauri-dist"
  },
  "app": {
    "windows": [
      {
        "title": "Novyx Vault",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Novyx Vault needs microphone access to record and transcribe audio.",
        "NSScreenCaptureUsageDescription": "Novyx Vault needs screen capture access to record system audio from meetings and webinars."
      }
    }
  }
}
