# =============================================================================
# Novyx Vault Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
#
# Variables marked [VERCEL] must also be set in Vercel project settings
# (Settings > Environment Variables) for production deployment.
#
# Variables marked [LOCAL-ONLY] are only needed for local development.
# =============================================================================

# --- Storage Mode ---
# Set to "supabase" for cloud mode (auth + Supabase storage).
# Leave empty or unset for desktop/local mode (filesystem storage, no auth).
# [VERCEL] Set to "supabase"
STORAGE_MODE=

# --- Supabase (required for cloud mode) ---
# [VERCEL] Set both of these
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — used server-side only for:
#   - Novyx key provisioning (writing to profiles)
#   - Desktop-to-cloud import (marking import complete)
# NEVER expose this to the client. No NEXT_PUBLIC_ prefix.
# [VERCEL] Required
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Novyx (AI memory) ---
# Desktop mode: personal API key used for all memory operations.
# [LOCAL-ONLY] Not needed on Vercel (each user gets their own key via provisioning)
NOVYX_MEMORY_API_KEY=

# Admin signing key for provisioning new user keys on sign-up.
# Used to generate HMAC-signed admin tokens for the Novyx API.
# [VERCEL] Required for user sign-up to work
NOVYX_ADMIN_KEY=

# --- Upstash Redis (rate limiting) ---
# Required for rate limiting in production (serverless-compatible).
# Create a free database at https://console.upstash.com
# [VERCEL] Required
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Deployed smoke tests ---
# [LOCAL-ONLY] Used by `npm run test:cloud-smoke`.
# Requires a disposable cloud test account because the suite creates, publishes,
# unpublishes, deletes, and purges a Smoke Tests note.
CLOUD_SMOKE_BASE_URL=https://vault.novyxlabs.com
CLOUD_SMOKE_EMAIL=
CLOUD_SMOKE_PASSWORD=
