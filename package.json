{
  "name": "novyx-vault",
  "version": "0.3.0",
  "description": "An open-source AI workspace with persistent memory, powered by Novyx",
  "license": "MIT",
  "homepage": "https://vault.novyxlabs.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/novyxlabs/novyx-vault"
  },
  "author": "Novyx Labs <blake@novyxlabs.com> (https://novyxlabs.com)",
  "keywords": [
    "ai",
    "notes",
    "markdown",
    "knowledge-base",
    "knowledge-graph",
    "ai-memory",
    "notion-alternative",
    "obsidian-alternative",
    "second-brain",
    "self-hosted",
    "local-first",
    "nextjs",
    "tauri"
  ],
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "tauri:dev": "STORAGE_MODE= NEXT_PUBLIC_SUPABASE_URL= tauri dev",
    "tauri:prepare": "STORAGE_MODE= NEXT_PUBLIC_SUPABASE_URL= TAURI=1 npm run build && rm -rf .tauri-dist && cp -R .next/standalone .tauri-dist && mv .tauri-dist/node_modules .tauri-dist/deps && cp -R .next/static .tauri-dist/.next/static && cp -R public .tauri-dist/public",
    "tauri:build": "STORAGE_MODE= NEXT_PUBLIC_SUPABASE_URL= TAURI=1 tauri build",
    "test": "npx playwright test --project=functional",
    "test:unit": "vitest run",
    "test:cloud-smoke": "PLAYWRIGHT_SKIP_WEBSERVER=1 npx playwright test --project=cloud-smoke",
    "test:demo": "npx playwright test --project=demo",
    "demo": "npx playwright test --config=demo/playwright.config.ts --headed"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.15",
    "@huggingface/transformers": "^3.8.1",
    "@sentry/nextjs": "^10.46.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "@vercel/analytics": "^1.6.1",
    "lucide-react": "^0.575.0",
    "motion": "^12.38.0",
    "next": "^16.2.3",
    "novyx": "^3.2.0",
    "openai": "^6.25.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@tauri-apps/cli": "^2.10.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
